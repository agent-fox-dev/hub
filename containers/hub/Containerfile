ARG BUILDER=registry.redhat.io/ubi10/go-toolset:latest
ARG RUNTIME=registry.access.redhat.com/ubi10/ubi-micro:latest

# ---------- build ----------
FROM ${BUILDER} AS build

ARG VERSION=dev
ARG BUILD=dev
ARG BUILD_TIME=

USER root
WORKDIR /build

RUN git clone https://github.com/txsvc/apikit.git apikit
WORKDIR /build/hub
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w \
      -X github.com/txsvc/apikit.Version=${VERSION} \
      -X github.com/txsvc/apikit.Commit=${BUILD} \
      -X github.com/txsvc/apikit.BuildTime=${BUILD_TIME} \
      -X github.com/txsvc/apikit/internal/cli.Version=${VERSION} \
      -X github.com/txsvc/apikit/internal/cli.Build=${BUILD} \
      -X github.com/txsvc/apikit.TokenPrefix=af \
      -X github.com/txsvc/apikit/internal/cli.TokenPrefix=af" \
    -o hub ./cmd/af-hub
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w \
      -X github.com/txsvc/apikit.Version=${VERSION} \
      -X github.com/txsvc/apikit.Commit=${BUILD} \
      -X github.com/txsvc/apikit.BuildTime=${BUILD_TIME} \
      -X github.com/txsvc/apikit/internal/cli.Version=${VERSION} \
      -X github.com/txsvc/apikit/internal/cli.Build=${BUILD} \
      -X github.com/txsvc/apikit.TokenPrefix=af \
      -X github.com/txsvc/apikit/internal/cli.TokenPrefix=af" \
    -o afc ./cmd/afc

# ---------- runtime ----------
FROM ${RUNTIME}

ENV XDG_CONFIG_HOME=/config
ENV XDG_DATA_HOME=/data

EXPOSE 80
EXPOSE 8080

# CA certificates for outbound TLS (ubi-micro ships without them)
COPY --from=build /etc/pki/tls/certs/ca-bundle.crt /etc/pki/tls/certs/ca-bundle.crt

RUN mkdir -p /config/af-hub /data/af-hub

# copy a default config (override at runtime by mounting /config/af-hub/config.toml)
COPY containers/hub/config.toml /config/af-hub/config.toml

# copy the run script
COPY containers/hub/run /usr/local/bin/run

# copy the binaries
COPY --from=build /build/hub/hub /usr/bin/hub
COPY --from=build /build/hub/afc /usr/bin/afc

RUN chmod +x /usr/local/bin/run /usr/bin/hub
RUN chmod +x /usr/local/bin/run /usr/bin/afc

VOLUME /config
VOLUME /data

CMD ["/usr/local/bin/run"]
