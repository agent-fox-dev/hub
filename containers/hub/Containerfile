ARG BUILDER=registry.redhat.io/ubi10/go-toolset:latest
ARG RUNTIME=registry.access.redhat.com/ubi10/ubi-micro:latest

# ---------- build ----------
FROM ${BUILDER} AS build

ARG VERSION=dev

USER root
WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w -X github.com/agent-fox-dev/hub/internal/server.Version=${VERSION}" \
    -o af-hub ./cmd/af-hub
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w -X github.com/agent-fox-dev/hub/cmd/afc.Version=${VERSION}" \
    -o afc ./cmd/afc

# ---------- runtime ----------
FROM ${RUNTIME}

ENV XDG_CONFIG_HOME=/config/af-hub
ENV XDG_DATA_HOME=/data/af-hub

EXPOSE 80
EXPOSE 8080

RUN mkdir -p /config/af-hub /data/af-hub

# copy the run script
COPY containers/hub/run /usr/local/bin/run

# copy the binaries
COPY --from=build /build/af-hub /usr/bin/af-hub
COPY --from=build /build/afc /usr/bin/afc

RUN chmod +x /usr/local/bin/run /usr/bin/af-hub
RUN chmod +x /usr/local/bin/run /usr/bin/afc

VOLUME /config
VOLUME /data

CMD ["/usr/local/bin/run"]
